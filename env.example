# RunMate Backend — Variáveis de Ambiente
# Copia este ficheiro para .env e preenche os valores
# No Railway, define estas variáveis em Settings > Variables

# JWT Secret — usa uma string longa e aleatória
JWT_SECRET=muda-isto-para-uma-string-muito-secreta-e-longa-2025

# Porto onde o servidor corre (Railway define isto automaticamente)
PORT=3000

# Ambiente (development ou production)
NODE_ENV=production

# Caminho da base de dados SQLite
# No Railway usa /app/data/runmate.db ou deixa o default
DB_PATH=./runmate.db
